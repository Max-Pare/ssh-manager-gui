PORT=3001
ENCRYPTION_KEY=32-char-key
# Shared bearer token clients must send. Random 32+ char string.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=change-me-to-a-random-32-char-string
NODE_ENV=development
# Comma-separated allowlist of browser Origins for CORS + the terminal WebSocket.
ALLOWED_ORIGIN=http://localhost:3000
POLL_INTERVAL_SECS=30
# Directory SSH private keys must live in (device keyPath is confined here).
# Default: ~/.ssh
# SSH_KEY_DIR=/home/youruser/.ssh
