# ── Backend (Express, src reads these) ──────────────────────────────
# AES-256 key for stored SSH passwords. 32 chars. Server exits if missing.
ENCRYPTION_KEY=change-me-32-char-random-string

# Bearer token clients must send. Generate: openssl rand -hex 32
# Operators enter this on the frontend login screen (stored in the browser's
# localStorage). It is NOT baked into the frontend bundle.
API_TOKEN=change-me-shared-secret

# Backend listen port
PORT=3001

# Bind address. 0.0.0.0 = reachable from other machines (needed for remote server).
# 127.0.0.1 = localhost only.
HOST=0.0.0.0

NODE_ENV=production

# CORS allowlist = the ORIGIN the browser loads the frontend from.
# Must match scheme+host+port exactly. Frontend auto-switched to 3002.
ALLOWED_ORIGIN=http://SERVER_IP:3002

# Metrics poll interval (seconds)
POLL_INTERVAL_SECS=30

# ── Frontend (Next.js, NEXT_PUBLIC_* inlined at BUILD time) ──────────
# Where the browser reaches the backend. NOT localhost — browser runs on
# the client machine. Use the server's IP/hostname reachable from client.
# Behind the TLS reverse proxy (see Caddyfile.example): https://your-host
NEXT_PUBLIC_API_URL=http://SERVER_IP:3001
