{
  "name": "ssh-device-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,yellow \"next dev\" \"nodemon backend/src/index.js\"",
    "dev:frontend": "next dev",
    "dev:backend": "nodemon backend/src/index.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:reset": "node -e \"require('fs').unlinkSync('backend/data/ssh-mgr.db')\" && echo 'DB reset'"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
